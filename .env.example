# Copy to .env and fill in the two API keys to run the real experiment.
# (For a keyless wiring check, set APP_USE_FAKES=1 — see README.)

# --- Provider API keys (only needed when APP_USE_FAKES=0) ---
# Anthropic (the context-writing model) and Voyage (embeddings). LiteLLM reads them.
RAG_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
RAG_EMBEDDING_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx   # Voyage key

# --- Models (any LiteLLM model string) ---
RAG_CONTEXT_MODEL=anthropic/claude-haiku-4-5        # cheap model that writes the context
RAG_EMBEDDING_MODEL=voyage/voyage-law-2             # embeddings (dim 1024)
RAG_DENSE_DIM=1024

# --- Contextual-retrieval strategy for the live ingest path ---
# none | per_chunk | per_document  (the experiment sweeps all three via the CLI flags)
RAG_CONTEXT_MODE=per_chunk
RAG_RETRIEVAL_MODE=dense                            # dense | hybrid (experiment uses dense)

# --- Datastores (the docker-compose service hostnames override these for the API) ---
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/company_brain
RAG_MILVUS_URI=http://localhost:19530
APP_BLOB_DIR=/data/blobs

# --- Dev auth: identity from a header, no service token ---
APP_AUTH_MODE=header

# --- Run everything on dependency-free fakes (no keys, no network) ---
APP_USE_FAKES=0

# --- Bulk ingest worker pool (in-process; no Celery/Redis) ---
RAG_BULK_INGEST_CONCURRENCY=4
